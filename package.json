{
  "name": "deepseek-web-local-api",
  "version": "0.1.0",
  "description": "Local OpenAI-compatible wrapper around chat.deepseek.com",
  "license": "MIT",
  "keywords": [
    "deepseek",
    "openai-compatible",
    "sse",
    "playwright",
    "local-api"
  ],
  "packageManager": "npm@11.12.1",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",

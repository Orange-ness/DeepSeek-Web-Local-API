HOST=127.0.0.1
PORT=8787
LOCAL_API_KEY=
CHROMIUM_PATH=/usr/bin/chromium
DATA_DIR=./.deepseek-web-api
LOGIN_TIMEOUT_MS=300000

# Optional password-first login for /auth/login/auto, scripts/smoke, and scripts/verify
DEEPSEEK_EMAIL=
DEEPSEEK_PASSWORD=

# Optional DeepSeek web endpoint overrides
DEEPSEEK_BASE_URL=https://chat.deepseek.com/api/v0
DEEPSEEK_SIGN_IN_URL=https://chat.deepseek.com/sign_in
DEEPSEEK_ORIGIN=https://chat.deepseek.com
DEEPSEEK_DS_POW_RESPONSE=

# Optional local client defaults
LOCAL_API_BASE_URL=http://127.0.0.1:8787
DEEPSEEK_LOCAL_MODEL=deepseek-web-chat
DEEPSEEK_LOCAL_SYSTEM=
DEEPSEEK_TEST_MESSAGE=Say hello in one short sentence.

# Optional advanced tuning
UPSTREAM_CONCURRENCY=1
CHAT_MAX_ATTEMPTS=3
RATE_LIMIT_RETRY_DELAY_MS=1500
QUEUE_TIMEOUT_MS=30000
MAX_QUEUE_SIZE=100
UPSTREAM_TIMEOUT_MS=60000
HEALTH_TIMEOUT_MS=2000
UPSTREAM_TRACE_LIMIT=20
UPSTREAM_TRACE_EVENT_LIMIT=64
UPSTREAM_TRACE_PREVIEW_CHARS=16000
